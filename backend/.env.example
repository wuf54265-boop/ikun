# 后端环境变量模板（复制为 .env 后填写）
APP_NAME=AI 数据分析助手
ENV=development
API_V1_PREFIX=/api/v1

# 文件系统存储（Parquet + SQLite 元数据）
DATA_DIR=./data
DB_PATH=./data/meta.db

# 上传限制（MB）
MAX_UPLOAD_MB=50

# CORS：前端开发地址
CORS_ORIGINS=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# 超大文件采样行数
SAMPLE_ROWS=50000
